DATABASE_URL="postgresql://user:password@host:5432/svc_appointments?sslmode=require"

HOST=0.0.0.0
PORT=3000

NODE_ENV=development

LOG_LEVEL=info

CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:3000

# ── Redis / Upstash (BullMQ) ─────────────────
# Use rediss:// (double s) for TLS connections (required by Upstash)
REDIS_URL=rediss://default:your_password@your-host.upstash.io:6379

# ── Clerk (auth) ────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend (emails) ─────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=turnos@tuclinica.com

# ── WhatsApp Cloud API ──────────────────────
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_RECIPIENT_PHONE=5491155551234
